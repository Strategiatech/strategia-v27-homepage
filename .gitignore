# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local tooling
.chrome-v8-check/
.kilo/
.claude/settings.local.json

# test output
/test-results/

# dev logs
.next-dev-*.log
.next-dev-*.err.log

# design reference screenshots
/v10-*.png
/v11-*.png
/v12-*.png

# session screenshot output (regenerated by shot-*.mjs scripts)
/screenshots/

# stray Windows temp paths that occasionally land in the repo root
/UsersAaron*

# stay-local working files (kept on disk, excluded from the public repo)
/CLAUDE.md
/AGENTS.md
/DEPLOY.md
/PROJECT.md
/client-request-email.md
